# Copy this file to .env (same directory) and fill in your Anthropic API key.
# .env is git-ignored; the key stays on this machine and is injected by Vite's
# dev proxy at runtime — it is NOT bundled into the client JavaScript.

ANTHROPIC_API_KEY=sk-ant-...

# Optional override (default: 2023-06-01)
# ANTHROPIC_VERSION=2023-06-01
